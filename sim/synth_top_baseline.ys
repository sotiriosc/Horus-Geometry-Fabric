# synth_top_baseline.ys — Sky130 HD synthesis of horus_top (baseline horus_nfe)
# System-level denominator: 4×4 systolic array (16 horus_nfe) + controller.
# Identical library and flow to synth_nfe_baseline.ys.
# Run from sim/ directory.
# Liberty: sky130_fd_sc_hd TT 025C 1v80
# Timing: not measured (OpenSTA not available).

read_verilog ../rtl/horus_nfe.v
read_verilog ../rtl/horus_systolic_array.v
read_verilog ../rtl/horus_controller.v
read_verilog ../rtl/horus_top.v

synth -top horus_top

dfflibmap -liberty /home/sotiriosc/.volare/volare/sky130/versions/c6d73a35f524070e85faff4a6a9eef49553ebc2b/sky130A/libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__tt_025C_1v80.lib

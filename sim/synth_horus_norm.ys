# synth_horus_norm.ys — Sky130 HD synthesis of horus_norm (standalone).
# Identical flow to synth_nfe_baseline.ys.  Run from sim/ directory.
# Liberty: sky130_fd_sc_hd TT 025C 1v80.
# Timing: not measured (OpenSTA not available in this environment).
read_verilog ../rtl/horus_norm.v
synth -top horus_norm
dfflibmap -liberty @LIBERTY@
abc -liberty @LIBERTY@
clean
stat -liberty @LIBERTY@
